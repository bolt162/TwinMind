{
  "name": "twinmind",
  "version": "1.0.0",
  "private": true,
  "description": "Desktop dictation + meeting transcription (V2 — utilityProcess audio path, pre-mixed ASR, SQLite outbox).",
  "main": "dist/main/main.js",
  "license": "MIT",
  "author": {
    "name": "TwinMind",
    "email": "support@twinmind.com"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node scripts/dev.cjs",
    "build": "npm run build:main && npm run build:renderer && electron-builder",
    "build:main": "node scripts/build.cjs",
    "build:renderer": "vite build",
    "build:mac": "npm run build:main && npm run build:renderer && electron-builder --mac",
    "build:win": "npm run build:main && npm run build:renderer && electron-builder --win",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.audio-process.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,md}\"",
    "rebuild:electron": "electron-builder install-app-deps",
    "switch:app": "electron-builder install-app-deps --arch arm64 && npm run rebuild:coreaudio:electron && node -e \"require('fs').writeFileSync('node_modules/.twinmind-native-abi','electron')\"",
    "switch:tests": "npm rebuild better-sqlite3 uiohook-napi @twinmind/coreaudio-darwin && node -e \"require('fs').writeFileSync('node_modules/.twinmind-native-abi','tests')\"",
    "rebuild:coreaudio:electron": "cd native/coreaudio-darwin && npx node-gyp rebuild --target=$(node -p \"require('../../node_modules/electron/package.json').version\") --dist-url=https://electronjs.org/headers --arch=arm64"
  },
  "optionalDependencies": {
    "@twinmind/coreaudio-darwin": "file:./native/coreaudio-darwin"
  },
  "dependencies": {
    "@amplitude/analytics-node": "^1.3.0",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@sentry/electron": "^5.5.0",
    "audiotee": "^0.0.7",
    "better-sqlite3": "^11.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.5",
    "ffmpeg-static": "^5.2.0",
    "lucide-react": "^0.518.0",
    "pino": "^9.4.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.1",
    "uiohook-napi": "^1.5.4",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@electron/notarize": "^3.0.1",
    "@playwright/test": "^1.48.0",
    "@tailwindcss/vite": "^4.1.10",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.16.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^8.2.2",
    "cross-env": "^10.0.0",
    "electron": "^36.9.5",
    "electron-builder": "^26.4.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "pino-pretty": "^11.2.2",
    "playwright": "^1.48.0",
    "postcss": "^8.5.6",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.10",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.3.5",
    "vitest": "^2.1.0",
    "wait-on": "^9.0.10"
  }
}
