# Copy this file to `.env.test` and fill in the values. `.env.test` is
# gitignored — never commit credentials.
#
# `npm run build:e2e` (and `npm run test:e2e`) builds the bundle with these
# values BAKED IN via esbuild's `define`, completely independent of the
# developer's prod `.env`. That's the point — running e2e tests must never
# pick up production backend URLs from a stale `.env`.
#
# The runtime fixture (tests/e2e/fixtures/app.ts) also loads this file so
# `TWINMIND_E2E_TEST_SECRET` reaches the OAuth helper at test time.

# ─── Test-only sign-in shortcut (read at test runtime, not baked) ──────────
# The "Test user secret" the dev webapp accepts on its /login?via_desktop
# page. The OAuth helper fills [data-testid="test-user-secret-input"] with
# this value and submits.
TWINMIND_E2E_TEST_SECRET=

# ─── TwinMind dev backend (baked at build time) ─────────────────────────────
TWINMIND_BACKEND_URL=https://dev.twinmind.com
TWINMIND_TRANSCRIBE_URL=https://dev.twinmind.com/api/transcribe
TWINMIND_SUMMARY_URL=https://dev.twinmind.com/api/summary
TWINMIND_APP_URL=https://dev.app.twinmind.com
TWINMIND_WEB_LOGIN_URL=https://dev.app.twinmind.com/login?via_desktop
VERCEL_PROTECTION_BYPASS=

# ─── Firebase dev project (baked at build time; public per Firebase docs) ──
FIREBASE_WEB_API_KEY=
FIREBASE_TENANT_ID=
FIREBASE_PROJECT_ID=
