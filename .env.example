# TwinMind V2 — runtime configuration.
# Anything set here is read once at composition. The TwinMind/Firebase/Google
# values below are REQUIRED — the app will refuse to sign in until they're set.
# These identifiers are public (OAuth client ID, Firebase project), not secrets.

# ============================================================
# TwinMind backend
# ============================================================
# Base URL for the TwinMind backend (no trailing slash needed; we strip it).
TWINMIND_BACKEND_URL=https://api-staging-thirdear.live
# Full URL of the chunk-transcription endpoint. Most deployments derive this
# from the backend URL (e.g. <BACKEND_URL>/api/v2/transcribe) but it's accepted
# as a full URL so different ASR backends are easy to point at.
TWINMIND_TRANSCRIBE_URL=https://api-staging-thirdear.live/api/v2/transcribe
# Per-meeting summary endpoint. Called once per completed meeting (after all
# chunks transcribe); request body does NOT include the transcript — the
# backend already has every chunk keyed by meeting_id.
TWINMIND_SUMMARY_URL=https://api-staging-thirdear.live/api/v2/summary
# Vercel deployment-protection bypass token (sent as `x-vercel-protection-bypass`).
# Low-secret; required on staging deployments that have protection enabled.
VERCEL_PROTECTION_BYPASS=

# ============================================================
# Firebase Auth (REST endpoints only — no SDK at runtime)
# ============================================================
FIREBASE_WEB_API_KEY=
FIREBASE_TENANT_ID=
FIREBASE_PROJECT_ID=

# ============================================================
# Sign-in (system browser → web handoff → twinmind:// custom protocol)
# ============================================================
# The system browser opens this URL when the user clicks Sign In. The TwinMind
# webapp runs the Google OAuth dance and redirects back to
# `twinmind://auth/callback?token=<code>`. Defaults to the production webapp;
# override here to point at a staging webapp or a local dev server.
# TWINMIND_WEB_LOGIN_URL=https://thirdear-webapp-third-ear-ai.vercel.app/login?via_desktop

# ============================================================
# Per-mode model selection (optional)
# ============================================================
# Sent as the `model` form field on each transcribe request. The backend's
# `/api/v2/transcribe/choose` endpoint honors this. Defaults match V1:
# dictation → twinmind-fast, meeting mode → twinmind-pro. Override here to
# A/B against other backend models.
# TWINMIND_DICTATION_MODEL=twinmind-fast
# TWINMIND_MEETING_MODEL=twinmind-pro

# Base URL of the TwinMind web app — the "View Summary" button on completed
# meetings opens `${TWINMIND_APP_URL}/m/${session_id}` externally. Defaults to
# https://app.twinmind.com when unset.
# TWINMIND_APP_URL=https://app.twinmind.com

# ============================================================
# Provider overrides (optional)
# ============================================================
# ASR provider: 'twinmind' (default, real) or 'mock' (tests / dev). Groq has
# been removed; only these two are supported.
TWINMIND_ASR_PROVIDER=twinmind

# Log level: trace | debug | info | warn | error
TWINMIND_LOG_LEVEL=info

# Mic backend (dev override): native | mock
TWINMIND_MIC_BACKEND=native

# ============================================================
# Observability (optional)
# ============================================================
# TWINMIND_SENTRY_DSN=
# TWINMIND_AMPLITUDE_KEY=
