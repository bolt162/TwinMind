# TwinMind V2 — runtime configuration (optional; settings UI is source of truth).
# Anything set here is read once at composition. Settings UI overrides at runtime.

# ASR provider: groq | twinmind | mock
TWINMIND_ASR_PROVIDER=groq

# Groq config (user normally pastes the key in Settings; never bundle one).
GROQ_MODEL=whisper-large-v3
# GROQ_API_KEY=

# Auth provider: noop | twinmind_oauth
TWINMIND_AUTH_PROVIDER=noop

# Log level: trace | debug | info | warn | error
TWINMIND_LOG_LEVEL=info

# Mic backend (dev override): native | mock
TWINMIND_MIC_BACKEND=native
